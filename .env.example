# ============================================================
# Triunfo — Variables de entorno
# Copiar a .env y completar con valores reales
# ============================================================

# ------------------------------------------------------------
# Google Cloud — Proyecto y autenticación
# ------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=tu-proyecto-gcp
GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/service-account-key.json
# Alternativa: usar Application Default Credentials (gcloud auth application-default login)
# En ese caso dejar GOOGLE_APPLICATION_CREDENTIALS vacío

# ------------------------------------------------------------
# Vertex AI — Configuración de región
# ------------------------------------------------------------
VERTEX_AI_LOCATION=us-central1

# ------------------------------------------------------------
# Modelos Gemini — IDs en Vertex AI
# ------------------------------------------------------------
GEMINI_FLASH_LITE_MODEL=gemini-2.5-flash
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro-preview

# ------------------------------------------------------------
# Timeouts individuales por modelo (segundos)
# ------------------------------------------------------------
VERTEX_TIMEOUT_FLASH_LITE=20
VERTEX_TIMEOUT_FLASH=30
VERTEX_TIMEOUT_PRO=90

# ------------------------------------------------------------
# Orquestador Vertex (task-011)
# ------------------------------------------------------------
# Timeout global para el conjunto de los 3 modelos en paralelo
VERTEX_PARALLEL_TIMEOUT=120

# Estrategia de selección del resultado final:
#   fastest_valid      — primer modelo en responder con >= 3 campos no null
#   highest_confidence — modelo con mayor promedio de confidence
#   majority           — mini-conciliación entre los 3 (igual algoritmo que Spec-04)
VERTEX_SELECTION_STRATEGY=highest_confidence

# ------------------------------------------------------------
# Pipeline general
# ------------------------------------------------------------
# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Sede por defecto para el demo
DEFAULT_SEDE_ID=demo-001
