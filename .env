# ============================================================
# Triunfo — Entorno local de desarrollo
# NO commitear este archivo
# ============================================================

# ------------------------------------------------------------
# Google Cloud — Proyecto y autenticación
# ------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=triunfo-poc-dev
GOOGLE_APPLICATION_CREDENTIALS=

# ------------------------------------------------------------
# Vertex AI — Configuración de región
# ------------------------------------------------------------
VERTEX_AI_LOCATION=us-central1

# ------------------------------------------------------------
# Modelos Gemini — IDs en Vertex AI
# ------------------------------------------------------------
GEMINI_FLASH_LITE_MODEL=gemini-2.5-flash
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro-preview

# ------------------------------------------------------------
# Timeouts individuales por modelo (segundos)
# ------------------------------------------------------------
VERTEX_TIMEOUT_FLASH_LITE=20
VERTEX_TIMEOUT_FLASH=30
VERTEX_TIMEOUT_PRO=90

# ------------------------------------------------------------
# Orquestador Vertex (task-011)
# ------------------------------------------------------------
VERTEX_PARALLEL_TIMEOUT=120
VERTEX_SELECTION_STRATEGY=highest_confidence

# ------------------------------------------------------------
# Pipeline general
# ------------------------------------------------------------
LOG_LEVEL=INFO
DEFAULT_SEDE_ID=demo-001
