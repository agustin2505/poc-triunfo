# =============================================================================
# Triunfo — Variables de entorno
# Completar los valores marcados con COMPLETAR antes de ejecutar
# =============================================================================

# -----------------------------------------------------------------------------
# ANTHROPIC (Spec-19 — ClaudeVisionAgent)
# Obtener en: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=COMPLETAR

# -----------------------------------------------------------------------------
# GOOGLE CLOUD / VERTEX AI (Specs 13, 14, 15, 16)
# GOOGLE_CLOUD_PROJECT: ID del proyecto GCP (no el nombre display, el ID)
#   Encontrarlo en: GCP Console → selector de proyecto → columna "ID"
# VERTEX_AI_LOCATION: región donde está habilitado Vertex AI
#   Recomendado: us-central1 (más modelos disponibles)
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=COMPLETAR
VERTEX_AI_LOCATION=us-central1

# -----------------------------------------------------------------------------
# ACTIVACIÓN DEL PIPELINE DE IMÁGENES (Spec-20)
# true  → usa Claude + 3 Gemini en paralelo para archivos image/*
# false → usa el flujo mock original (útil para tests y demo sin credenciales)
# -----------------------------------------------------------------------------
USE_IMAGE_ORCHESTRATOR=true

# =============================================================================
# CONFIGURACIÓN OPCIONAL — defaults razonables, cambiar si hace falta
# =============================================================================

# Modelos (cambiar si querés probar otras versiones)
CLAUDE_VISION_MODEL=claude-sonnet-4-6
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro-preview
GEMINI_FLASH_LITE_MODEL=gemini-2.5-flash

# Timeouts (segundos)
CLAUDE_MAX_TOKENS=2048
IMAGEN_PARALLEL_TIMEOUT=120
VERTEX_PARALLEL_TIMEOUT=120

# Conciliación
VERTEX_SELECTION_STRATEGY=highest_confidence
IMAGEN_MIN_AGENTS_OK=1
THRESHOLD_CRITICO=0.90

# Weights por modelo en la conciliación (deben sumar 1.0)
WEIGHT_CLAUDE=0.35
WEIGHT_GEMINI_FLASH=0.30
WEIGHT_GEMINI_PRO=0.25
WEIGHT_GEMINI_FLASH_LITE=0.10
